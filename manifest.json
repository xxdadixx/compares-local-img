{
  "manifest_version": 3,
  "name": "Instagram Profile-Specific Matcher",
  "version": "1.3",
  "description": "Links specific local image folders to individual Instagram profiles with persistent background state.",
  "permissions": ["storage", "unlimitedStorage", "activeTab"],
  "host_permissions": ["https://*.instagram.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["content.js"]
    }
  ]
}
