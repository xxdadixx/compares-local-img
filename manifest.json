{
  "manifest_version": 3,
  "name": "Instagram Profile-Specific Matcher",
  "version": "2.0",
  "description": "Links specific local image folders to individual Instagram profiles via API background state.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://*.cdninstagram.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "cors_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://*.instagram.com/*"]
    }
  ]
}
